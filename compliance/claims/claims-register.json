{
  "version": "0.1.0",
  "status": "DRAFT",
  "updated": "2026-06-18",
  "notes": "WP10.10 claims register v0. Blocklists are CI-enforceable guards (WP4.2). Approved language is draft-pending-signoff. Required consumer-beta disclaimers are limiting statements and must pass lint. See claims-register.md for governance.",
  "exemptions": [
    {
      "scope": "packages/instruments verbatim renders",
      "reason": "Validated instruments render verbatim (safety invariant #2); their wording is governed by the licensing audit, not the claims lint."
    }
  ],
  "blocklists": {
    "sleep-treatment-claims": {
      "appliesTo": ["content/sleep", "marketing", "store-listings", "coach-fences"],
      "enforcement": "ci-blocking",
      "rationale": "E16: full CBT-I mechanics under wellbeing framing; treatment claims cross the MHRA medical-device line.",
      "patterns": [
        {
          "id": "sleep-treat-disorder",
          "pattern": "\\btreat(s|ing|ment)?\\b[^.!?]{0,50}\\b(insomnia|sleep\\s+(disorder|apnoea|apnea|problem)s?)\\b",
          "flags": "i",
          "rationale": "Treatment claims against a named disorder"
        },
        {
          "id": "sleep-cure-heal",
          "pattern": "\\b(cure|cures|curing|heal|heals|healing|remedy)\\b[^.!?]{0,50}\\b(insomnia|sleep)\\b",
          "flags": "i",
          "rationale": "Cure/heal claims"
        },
        {
          "id": "sleep-overcome-insomnia",
          "pattern": "\\b(beat|overcome|fix|end|banish|conquer|defeat|eliminate)\\b[^.!?]{0,40}\\binsomnia\\b",
          "flags": "i",
          "rationale": "Outcome claims targeting insomnia by name"
        },
        {
          "id": "sleep-diagnose",
          "pattern": "\\b(we|our\\s+app|the\\s+app|preventos|coach|programme|program)\\b\\s+(can\\s+|will\\s+|does\\s+|is\\s+designed\\s+to\\s+)?\\bdiagnos(e|es|ing|tic)\\b",
          "flags": "i",
          "rationale": "Positive diagnosis claims (sleep-scoped copy); signpost to GP instead. Negative disclaimers must pass."
        },
        {
          "id": "sleep-named-therapy",
          "pattern": "\\b(CBT-?I|cognitive\\s+behaviou?ral\\s+therapy)\\b",
          "flags": "i",
          "rationale": "Naming the clinical therapy is a treatment claim in marketing/app copy"
        },
        {
          "id": "sleep-our-therapy",
          "pattern": "\\b((our|this|the)\\s+(app'?s?\\s+)?therap(y|ies)|(sleep|digital|online)\\s+therapy|therapeutic)\\b",
          "flags": "i",
          "rationale": "Describing the product as therapy ('speak to a therapist' signposting still passes)"
        },
        {
          "id": "sleep-clinically-proven",
          "pattern": "\\b(clinical(ly)?|medical(ly)?|scientifically)\\s+(proven|validated|effective)\\b",
          "flags": "i",
          "rationale": "Efficacy claims requiring an evidence basis and sign-off we do not have"
        },
        {
          "id": "sleep-medication-comparison",
          "pattern": "\\b(replace|instead\\s+of|stop\\s+taking|quit|alternative\\s+to|better\\s+than|without)\\b[^.!?]{0,50}\\b(sleeping\\s+pills?|sleep\\s+(medication|meds)|hypnotics?|z-?drugs?|melatonin)\\b",
          "flags": "i",
          "rationale": "Medication-replacement claims; also a safety issue (never advise stopping medication)"
        },
        {
          "id": "sleep-device-claims",
          "pattern": "\\b(SaMD|MHRA[\\s-]?(cleared|approved|registered)|FDA[\\s-]?(cleared|approved)|CE[\\s-]?marked|UKCA[\\s-]?marked)\\b|\\b(is|are|as|registered\\s+as|approved\\s+as|cleared\\s+as)\\s+(a\\s+)?medical\\s+device\\b",
          "flags": "i",
          "rationale": "Regulatory-status claims; SaMD is a deferred owner decision. Negative disclaimers such as 'not a medical device' must pass."
        }
      ]
    },
    "alcohol-clinical-claims": {
      "appliesTo": ["content/alcohol", "marketing", "store-listings", "coach-fences"],
      "enforcement": "ci-blocking",
      "rationale": "E17: no in-app pathway for dependence; unsupervised withdrawal is dangerous; no 'safe drinking' messaging.",
      "patterns": [
        {
          "id": "alcohol-detox",
          "pattern": "\\b(detox(ification)?|withdrawal\\s+(management|plan|schedule|programme|program)|taper(ing)?\\s+off\\s+alcohol)\\b",
          "flags": "i",
          "rationale": "Detox/withdrawal guidance is clinically supervised territory — hard-stop referral only"
        },
        {
          "id": "alcohol-safe-drinking",
          "pattern": "\\b(safe\\s+(level\\s+of\\s+)?drinking|drink(ing)?\\s+safely|safe\\s+amount\\s+of\\s+alcohol)\\b",
          "flags": "i",
          "rationale": "UK CMO position: no safe level; use 'low-risk' framing"
        },
        {
          "id": "alcohol-treat-dependence",
          "pattern": "\\b(treat|cure|therapy\\s+for)\\b[^.!?]{0,50}\\b(alcoholism|alcohol\\s+(dependence|addiction|use\\s+disorder))\\b",
          "flags": "i",
          "rationale": "Dependence-treatment claims"
        }
      ]
    },
    "global-medical-claims": {
      "appliesTo": ["content/*", "marketing", "store-listings", "coach-fences"],
      "enforcement": "ci-blocking",
      "rationale": "Product-wide: no disease-treatment, guarantee, or miracle claims anywhere.",
      "patterns": [
        {
          "id": "global-treat-disease",
          "pattern": "\\b(we|our\\s+app|the\\s+app|preventos|coach|programme|program|quitting|quit|vaping\\s+less|drinking\\s+less)\\b\\s+(can\\s+|will\\s+|does\\s+|is\\s+designed\\s+to\\s+)?\\b(treats?|cures?|prevents?|reverses?)\\b[^.!?]{0,50}\\b(disease|cancer|COPD|heart\\s+disease|stroke|diabetes|depression|anxiety\\s+disorder)\\b",
          "flags": "i",
          "rationale": "Disease-outcome claims. Negative required disclaimers must pass."
        },
        {
          "id": "global-diagnosis",
          "pattern": "\\b(we|our\\s+app|the\\s+app|preventos|coach|programme|program)\\b\\s+(can\\s+|will\\s+|does\\s+|is\\s+designed\\s+to\\s+)?\\bdiagnos(e|es|ing)\\b[^.!?]{0,50}\\b(condition|disease|disorder|dependence|addiction|insomnia|COPD|depression|anxiety)\\b",
          "flags": "i",
          "rationale": "Product-wide no-diagnosis posture; required negative disclaimers must pass"
        },
        {
          "id": "global-emergency-care",
          "pattern": "\\b(24\\/7|round-the-clock|live)\\s+(clinical\\s+)?(monitoring|emergency\\s+support|crisis\\s+support)\\b|\\b(emergency\\s+care|urgent\\s+care)\\s+(in|through|from)\\s+(the\\s+)?app\\b",
          "flags": "i",
          "rationale": "Do not promise emergency care, live monitoring, or crisis support coverage unless staffed and legally approved"
        },
        {
          "id": "global-regulatory-status",
          "pattern": "\\b(SaMD|MHRA[\\s-]?(cleared|approved|registered)|FDA[\\s-]?(cleared|approved)|CE[\\s-]?marked|UKCA[\\s-]?marked)\\b|\\b(is|are|as|registered\\s+as|approved\\s+as|cleared\\s+as)\\s+(a\\s+)?medical\\s+device\\b",
          "flags": "i",
          "rationale": "No regulatory-status or medical-device claims without formal clearance; negative disclaimers must pass"
        },
        {
          "id": "global-guarantee",
          "pattern": "\\bguarantee[ds]?\\b[^.!?]{0,40}\\b(quit|results?|success|abstinence|sobriety|sleep)\\b",
          "flags": "i",
          "rationale": "Outcome guarantees"
        },
        {
          "id": "global-miracle",
          "pattern": "\\b(miracle|miraculous|magic(al)?\\s+(cure|fix|solution))\\b",
          "flags": "i",
          "rationale": "Miracle claims"
        },
        {
          "id": "global-nrt-prescribing",
          "pattern": "\\b(we|app)\\s+(prescribe|recommend\\s+a\\s+dose)|\\bdosage\\s+(plan|schedule)\\s+for\\s+(NRT|nicotine\\s+(patch|gum|replacement))\\b",
          "flags": "i",
          "rationale": "NRT support is usage technique only; prescribing/dosing belongs to clinicians"
        }
      ]
    }
  },
