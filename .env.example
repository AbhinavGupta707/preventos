# PreventOS local/beta environment template.
# Copy to .env for local use. Never commit real secrets.

# Shared Postgres connection used by apps/api, apps/worker, apps/console, and
# integration tests. Matches docker-compose.yml.
DATABASE_URL=postgres://preventos:preventos_dev@localhost:5432/preventos

# apps/api
# Fastify listen settings. Hosted environments usually require HOST=0.0.0.0.
PORT=3001
# HOST=0.0.0.0

# Local development only: enables POST /dev/session as a Clerk stand-in.
# Leave unset/false for any shared, staging, beta, or production environment.
ALLOW_DEV_SESSIONS=false
# DEV_SESSION_TOKEN=dev-local-token
# DEV_SESSION_PERSON_ID=00000000-0000-0000-0000-000000000000

# apps/web and apps/console
# Server-side URL used by web API routes to mirror app and marketing writes to
# apps/api. Leave unset for fully local/offline web flows with .data fallback.
# PREVENTOS_API_URL=http://127.0.0.1:3001

# apps/mobile
# Expo inlines EXPO_PUBLIC_* at build time. Leave unset for MockApi/offline
# previews. Set for internal builds that should talk to a reachable API.
# EXPO_PUBLIC_API_URL=https://api.beta.preventos.example

# Coach LLM provider selection, in order:
# 1. FIREWORKS_API_KEY -> FireworksCoachProvider
# 2. ANTHROPIC_API_KEY -> ClaudeCoachProvider
# 3. neither -> deterministic FakeCoachProvider
# CI and local verification should normally run with no LLM key.
# FIREWORKS_API_KEY=
# ANTHROPIC_API_KEY=
# COACH_MODEL=accounts/fireworks/models/llama-v3p3-70b-instruct

# apps/worker
# Optional override for content pack loading. Defaults to ./content from repo root.
# CONTENT_ROOT=/absolute/path/to/content
# PREVENTOS_CONTENT_ROOT=/absolute/path/to/content

# apps/web rate limiting
# Number of trusted reverse-proxy hops for waitlist/events client IP extraction.
RATE_LIMIT_TRUSTED_PROXIES=1

# Future Clerk activation placeholders. The current code still uses FakeAuthProvider
# and dev sessions; do not set these expecting production auth until the adapter is
# implemented and wired.
# CLERK_SECRET_KEY=
# CLERK_PUBLISHABLE_KEY=
# CLERK_WEBHOOK_SECRET=
